# Python
__pycache__/
*.py[cod]
*.pyo
.env
# Windows Explorer appends .txt when extensions are hidden, so ".env" becomes
# ".env.txt" and slips past a bare ".env" rule. Catch the whole family.
.env.*
!.env.example

# Streamlit auth secrets (OIDC client credentials) — never commit
.streamlit/secrets.toml

# Temp file for `git commit -F` (PowerShell-safe commit messages, see HANDOFF §8)
.git_commit_msg.txt

# Virtuelle Umgebung
.venv/
venv/
env/

# Generierte Daten (werden zur Laufzeit erzeugt)
data/

# Publizierte Analyse-JSONs des taeglichen Review-Laufs (statisches Datenfundament der Research-Seiten)
!public/data/
!public/data/**

# Jupyter
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# Generierte Bilder
notebooks/*.png

# IDE
.vscode/
.idea/

# macOS
.DS_Store

# Claude Code Konfiguration (persönlich, nicht committen)
.claude/

# Kursabgaben / PDFs
*.pdf
!reports/FINAL_REPORT.pdf
*.docx

# --- Ergänzt: vor versehentlichem Commit grosser/fremder Artefakte schützen ---
