# Streamlit auth secrets — copy to .streamlit/secrets.toml (gitignored) to enable
# Google sign-in. WITHOUT this file the terminal runs in open local-research mode:
# no sign-in button, Settings page unrestricted. WITH it, Settings fail closed and
# require a signed-in account from the admin allowlist below.
#
# Google OIDC setup (console.cloud.google.com):
#   1. APIs & Services -> OAuth consent screen: External, app name, your email.
#   2. Credentials -> Create credentials -> OAuth client ID -> Web application.
#   3. Authorized redirect URI: exactly the redirect_uri below (path must be
#      /oauth2callback). For production use https://your-domain/oauth2callback.
#   4. Paste client ID/secret here. Generate cookie_secret with:
#      python -c "import secrets; print(secrets.token_hex(32))"
#
# Notes: identity cookie lasts 30 days (not configurable). Streamlit 1.57.0 had a
# login-cookie regression — requirements.txt already pins >=1.58.

[auth]
redirect_uri = "http://localhost:8503/oauth2callback"
cookie_secret = "REPLACE_WITH_RANDOM_HEX"
client_id = "REPLACE.apps.googleusercontent.com"
client_secret = "REPLACE"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
# Optional: skip Google's account chooser after logout
# client_kwargs = { "prompt" = "select_account" }

# Admin allowlist for the Settings page. The ADMIN_EMAILS environment variable
# (comma-separated) takes precedence over this list.
[admin]
emails = ["you@example.com"]
