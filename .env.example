# Prediction Market Terminal
# This app is research/paper-only by default. It does not place live orders.

# Paper Copy-Trading Defaults
COPY_TARGET_WALLET=0x204f72f35326db932158cba6adff0b9a1da95e14
PAPER_START_CASH=1000
COPY_SCALE=0.01
MAX_ORDER_EQUITY_PCT=0.05
LIVE_TRADING_ENABLED=false

# Fast public-chain polling for the paper copy runner.
POLYGON_RPC_URL=https://polygon-pokt.nodies.app
FAST_CHAIN_POLL_INTERVAL=1
PUBLIC_API_FALLBACK_INTERVAL=30
SETTLEMENT_SYNC_INTERVAL=180

# Reserved for a later real-order mode; unused while LIVE_TRADING_ENABLED=false.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=

# Telegram alert delivery (BotFather token + target chat id). Env values override
# data/app_settings.json and are never written back to disk. Leave empty to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin allowlist for the Settings page when Google sign-in is enabled via
# .streamlit/secrets.toml [auth] (see .streamlit/secrets.toml.example).
# Comma-separated; overrides [admin].emails in secrets.toml. Leave empty to keep
# the allowlist in secrets.toml. Without [auth] secrets this has no effect.
ADMIN_EMAILS=
